# Supabase — get these from your project settings > API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key

# Without these, the Eid card feature runs in demo mode (localStorage only)

# Moyasar — get these from your Moyasar dashboard
# MOYASAR_PUBLIC_KEY is used client-side (safe to expose)
# MOYASAR_SECRET is used server-side only (keep secret)
MOYASAR_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
MOYASAR_SECRET=sk_test_xxxxxxxxxxxxxxxxxxxx

# Public URL used for payment callback (important when testing on mobile)
# Example: https://your-domain.com or https://xxxxx.ngrok-free.app
PUBLIC_APP_URL=https://your-domain.com
