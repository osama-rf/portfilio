  type Lang = "en" | "ar";
  let currentLang: Lang = "en";

  // Check saved preference; portfolio defaults to EN if nothing is saved
  const saved = localStorage.getItem("pf-language") as Lang | null;
  if (saved === "ar" || saved === "en") {
    currentLang = saved;
  }

  // ── Helpers ────────────────────────────────────────────────────────────
  function set(id: string, text: string) {
    const el = document.getElementById(id);
    if (el) el.textContent = text;
  }

  function applyContent(lang: Lang) {
    const c = pfContent[lang];
    document.documentElement.setAttribute("dir", c.dir);
    document.documentElement.setAttribute("lang", c.lang);

    const toggle = document.getElementById("portfolio-lang-toggle");
    if (toggle) toggle.textContent = c.langToggle;

    set("pf-badge", c.badge);
    set("pf-title", c.title);
    set("pf-bio", c.bio);
    set("pf-cta-primary", c.ctaPrimary);
    set("pf-cta-secondary", c.ctaSecondary);
    set("pf-stat-years", c.statYears);
    set("pf-stat-apps", c.statApps);
    set("pf-stat-e2e", c.statE2e);
    set("pf-skills-title", c.skillsTitle);
    set("pf-skills-sub", c.skillsSub);
    set("pf-cat-frontend", c.catFrontend);
    set("pf-cat-backend", c.catBackend);
    set("pf-cat-db", c.catDb);
    set("pf-cat-integrations", c.catIntegrations);
    set("pf-expertise-title", c.expertiseTitle);
    set("pf-exp-payments-title", c.expPaymentsTitle);
