    set("pf-exp-auth-desc", c.expAuthDesc);
    set("pf-exp-mobile-title", c.expMobileTitle);
    set("pf-exp-mobile-desc", c.expMobileDesc);
    set("pf-projects-title", c.projectsTitle);
    set("pf-projects-sub", c.projectsSub);
    set("pf-zaai-desc", c.zaaiDesc);
    set("pf-talid-desc", c.talidDesc);
    set("pf-kedan-desc", c.kedanDesc);
    set("pf-contact-title", c.contactTitle);
    set("pf-contact-sub", c.contactSub);
    set("pf-whatsapp-btn", c.whatsappBtn);
    set("pf-site-btn", c.siteBtn);

    // Update nav links text
    const navLinks = document.querySelectorAll(".portfolio-nav");
    const navTexts = [c.navAbout, c.navSkills, c.navProjects, c.navContact];
    navLinks.forEach((link, i) => {
      if (navTexts[i]) link.textContent = navTexts[i];
    });

    // CTA button inner span update for primary cta (has icon + span)
    const ctaPrimarySpan = document.querySelector("#pf-cta-primary span:last-child") as HTMLElement;
    if (ctaPrimarySpan) ctaPrimarySpan.textContent = c.ctaPrimary;

    const ctaSecondarySpan = document.querySelector("#pf-cta-secondary span:first-child") as HTMLElement;
    if (ctaSecondarySpan) ctaSecondarySpan.textContent = c.ctaSecondary;
  }

  // Initial render
  applyContent(currentLang);

  // ── Language toggle ────────────────────────────────────────────────────
  document.getElementById("portfolio-lang-toggle")?.addEventListener("click", () => {
    currentLang = currentLang === "en" ? "ar" : "en";
    localStorage.setItem("pf-language", currentLang);
    applyContent(currentLang);
  });

  // ── Theme toggle ───────────────────────────────────────────────────────
  const themeBtn = document.getElementById("portfolio-theme-toggle");
  const sunIcon = document.getElementById("p-sun-icon");
  const moonIcon = document.getElementById("p-moon-icon");

  function updateThemeIcon() {
    if (themeStore.isDark) {
      moonIcon?.classList.add("hidden");
      sunIcon?.classList.remove("hidden");
    } else {
      moonIcon?.classList.remove("hidden");
      sunIcon?.classList.add("hidden");
    }
  }

  themeBtn?.addEventListener("click", () => {
    themeStore.toggleTheme();
    updateThemeIcon();
  });

  updateThemeIcon();
</script>
