---
---

<section id="expertise" class="py-16 border-t border-white/[0.06]">
  <div class="mb-10 text-center">
    <p id="te-label" class="text-xs font-semibold text-primary uppercase tracking-widest mb-3">الخبرة التقنية</p>
    <h2 id="te-title" class="text-2xl font-serif font-bold text-white mb-3">تقنيات وتكاملات حقيقية</h2>
    <p id="te-sub" class="text-neutral text-sm max-w-sm mx-auto leading-relaxed">
      بنينا تطبيقات بها مدفوعات حقيقية، إشعارات فورية، وقواعد بيانات تتحمل الحمل العالي
    </p>
  </div>

  <!-- Integration highlights -->
  <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 mb-8">
    <div class="te-card rounded-xl border border-white/[0.06] bg-white/[0.02] p-4 hover:border-primary/20 hover:bg-white/[0.03] transition-all duration-300">
      <div class="flex items-center gap-2 mb-2">
        <span class="text-lg">💳</span>
        <span id="te-payments-title" class="text-xs font-semibold text-white">تكامل المدفوعات</span>
      </div>
      <div class="flex flex-wrap gap-1">
        <span class="te-chip">Moyasar</span>
        <span class="te-chip">Tamara</span>
        <span class="te-chip">Stripe</span>
        <span class="te-chip">STC Pay</span>
      </div>
    </div>

    <div class="te-card rounded-xl border border-white/[0.06] bg-white/[0.02] p-4 hover:border-primary/20 hover:bg-white/[0.03] transition-all duration-300">
      <div class="flex items-center gap-2 mb-2">
        <span class="text-lg">📧</span>
        <span id="te-mail-title" class="text-xs font-semibold text-white">البريد والإشعارات</span>
      </div>
      <div class="flex flex-wrap gap-1">
        <span class="te-chip">Resend</span>
        <span class="te-chip">Firebase FCM</span>
        <span class="te-chip">OneSignal</span>
      </div>
    </div>

    <div class="te-card rounded-xl border border-white/[0.06] bg-white/[0.02] p-4 hover:border-primary/20 hover:bg-white/[0.03] transition-all duration-300">
      <div class="flex items-center gap-2 mb-2">
        <span class="text-lg">🗄️</span>
        <span id="te-db-title" class="text-xs font-semibold text-white">Supabase وقواعد البيانات</span>
      </div>
      <div class="flex flex-wrap gap-1">
        <span class="te-chip">Supabase</span>
        <span class="te-chip">MongoDB</span>
        <span class="te-chip">PostgreSQL</span>
        <span class="te-chip">Redis</span>
      </div>
    </div>

    <div class="te-card rounded-xl border border-white/[0.06] bg-white/[0.02] p-4 hover:border-primary/20 hover:bg-white/[0.03] transition-all duration-300">
      <div class="flex items-center gap-2 mb-2">
        <span class="text-lg">⚡</span>
        <span id="te-highload-title" class="text-xs font-semibold text-white">تطبيقات الحمل العالي</span>
      </div>
      <div class="flex flex-wrap gap-1">
        <span class="te-chip">Caching</span>
        <span class="te-chip">Queuing</span>
        <span class="te-chip">CDN</span>
        <span class="te-chip">Scaling</span>
      </div>
    </div>

    <div class="te-card rounded-xl border border-white/[0.06] bg-white/[0.02] p-4 hover:border-primary/20 hover:bg-white/[0.03] transition-all duration-300">
      <div class="flex items-center gap-2 mb-2">
        <span class="text-lg">📊</span>
        <span id="te-bigdata-title" class="text-xs font-semibold text-white">استعلامات البيانات الضخمة</span>
      </div>
      <div class="flex flex-wrap gap-1">
        <span class="te-chip">Aggregation</span>
        <span class="te-chip">Indexing</span>
        <span class="te-chip">RLS</span>
        <span class="te-chip">Migrations</span>
      </div>
    </div>

    <div class="te-card rounded-xl border border-white/[0.06] bg-white/[0.02] p-4 hover:border-primary/20 hover:bg-white/[0.03] transition-all duration-300">
      <div class="flex items-center gap-2 mb-2">
        <span class="text-lg">📱</span>
        <span id="te-mobile-title" class="text-xs font-semibold text-white">تطبيقات الجوال</span>
      </div>
      <div class="flex flex-wrap gap-1">
        <span class="te-chip">React Native</span>
        <span class="te-chip">Expo</span>
        <span class="te-chip">iOS & Android</span>
      </div>
    </div>
  </div>

  <!-- Portfolio CTA -->
  <div class="text-center">
    <a href="/portfolio" id="te-portfolio-link"
      class="inline-flex items-center gap-2 px-6 py-3 rounded-full border border-primary/30 bg-primary/5 text-primary text-sm font-semibold hover:bg-primary/10 hover:border-primary/50 transition-all duration-300">
      <span>شوف بورتفوليو أسامة كاملاً</span>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
      </svg>
    </a>
  </div>
</section>

<style>
  .te-chip {
    display: inline-flex;
    align-items: center;
    padding: 0.1rem 0.45rem;
    border-radius: 9999px;
    font-size: 0.6rem;
    font-weight: 500;
    background: rgba(99, 102, 241, 0.08);
    border: 1px solid rgba(99, 102, 241, 0.15);
    color: #a5b4fc;
    white-space: nowrap;
  }

  html.light .te-chip {
    background: rgba(99, 102, 241, 0.07);
    border-color: rgba(99, 102, 241, 0.18);
  }

  html.light .te-card {
    border-color: rgba(0, 0, 0, 0.06) !important;
    background: rgba(0, 0, 0, 0.01) !important;
  }

  html.light .te-card:hover {
    border-color: rgba(99, 102, 241, 0.2) !important;
    background: rgba(99, 102, 241, 0.03) !important;
  }
</style>

<script>
  import { TRANSLATIONS } from "@config";
  import { languageStore } from "@app/language-store";

  const teContent = {
    ar: {
      label: "الخبرة التقنية",
      title: "تقنيات وتكاملات حقيقية",
      sub: "بنينا تطبيقات بها مدفوعات حقيقية، إشعارات فورية، وقواعد بيانات تتحمل الحمل العالي",
      paymentsTitle: "تكامل المدفوعات",
      mailTitle: "البريد والإشعارات",
      dbTitle: "Supabase وقواعد البيانات",
      highloadTitle: "تطبيقات الحمل العالي",
      bigdataTitle: "استعلامات البيانات الضخمة",
      mobileTitle: "تطبيقات الجوال",
      portfolioLink: "شوف بورتفوليو أسامة كاملاً",
    },
    en: {
      label: "Technical Expertise",
      title: "Real Integrations & Technologies",
      sub: "Apps with real payments, push notifications, and databases built for high load",
      paymentsTitle: "Payment Integrations",
      mailTitle: "Mail & Notifications",
      dbTitle: "Supabase & Databases",
      highloadTitle: "High-Load Apps",
      bigdataTitle: "Big Data Queries",
      mobileTitle: "Mobile Apps",
      portfolioLink: "View Osama's Full Portfolio",
    },
  };

  function updateTE() {
    const lang = languageStore.language as "en" | "ar";
    const c = teContent[lang] || teContent.ar;

    const set = (id: string, text: string) => {
      const el = document.getElementById(id);
      if (el) el.textContent = text;
    };

    set("te-label", c.label);
    set("te-title", c.title);
    set("te-sub", c.sub);
    set("te-payments-title", c.paymentsTitle);
    set("te-mail-title", c.mailTitle);
    set("te-db-title", c.dbTitle);
    set("te-highload-title", c.highloadTitle);
    set("te-bigdata-title", c.bigdataTitle);
    set("te-mobile-title", c.mobileTitle);

    const link = document.getElementById("te-portfolio-link");
    if (link) link.querySelector("span")!.textContent = c.portfolioLink;
  }

  window.addEventListener("language-change", updateTE);
  updateTE();
</script>
