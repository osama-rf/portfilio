---
import Section from "./Section.astro";

const partners = [
  { name: "STC", src: "/partners/stc.svg" },
  { name: "Moyasar", src: "/partners/moyasar.png" },
  { name: "Alrajhi Bank", src: "/partners/alrajhi.svg" },
  { name: "Tamara", src: "/partners/tamara.png" },
  { name: "Kedan", src: "/kedan-logo.svg" },
  { name: "Glowpick", src: "/glowpick.png" },
];
---

<Section text="Trusted by" href="our-partners">
  <div class="partners-grid">
    <div class="partners-track">
      {partners.map((partner) => (
        <div class="partner-logo-card">
          <img src={partner.src} alt={`${partner.name} logo`} loading="lazy" decoding="async" />
        </div>
      ))}
    </div>
  </div>
</Section>

<style>
  :global(#section-title-our-partners) {
    text-align: center !important;
  }

  .partners-grid {
    width: 100%;
    padding: 1rem 0 0;
  }

  .partners-track {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 2.25rem 2.75rem;
  }

  .partner-logo-card {
    width: 150px;
    height: 84px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    padding: 0.45rem;
  }

  .partner-logo-card img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    opacity: 0.95;
  }

  @media (max-width: 768px) {
    .partners-track {
      gap: 1.5rem 1.75rem;
    }

    .partner-logo-card {
      width: 122px;
      height: 72px;
      padding: 0.5rem;
    }
  }
</style>
